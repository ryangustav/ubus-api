# OCI Vault integration
USE_OCI_VAULT=false
OCI_SECRET_OCID=ocid1.vaultsecret.oc1...

# Database
DATABASE_URL=mongodb://ubus:ubus@localhost:27017/ubus?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-in-production

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ubus.me